{
  "name": "job-scraper",
  "module": "src/index.ts",
  "scripts": {
    "scrape": "bun run src/index.ts",
    "scrape:dev": "DEV=true bun run src/index.ts",
    "report": "bun run src/utils/report.ts",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "bun test tests/unit",
    "test:e2e": "bunx playwright test",
    "test:e2e:dev": "DEV=true bunx playwright test",
    "test:e2e:headed": "bunx playwright test --headed",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:debug": "bunx playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "playwright": "^1.58.2",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.2"
  }
}
